FROM node:22-alpine AS builder

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy workspace config
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY packages/web/package.json ./packages/web/
COPY packages/shared/package.json ./packages/shared/

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source
COPY packages/web ./packages/web
COPY packages/shared ./packages/shared

# Generate Prisma client
RUN pnpm -F @wabi/shared db:generate

# Build
RUN pnpm -F @wabi/web build

# Production
FROM node:22-alpine

WORKDIR /app

RUN npm install -g pnpm

# Copy workspace config and built artifacts
COPY pnpm-workspace.yaml package.json pnpm-lock.yaml ./
COPY packages/web/package.json ./packages/web/
COPY packages/shared/package.json ./packages/shared/

RUN pnpm install --prod --frozen-lockfile

# Copy built artifacts
COPY --from=builder /app/packages/web/.next ./packages/web/.next
COPY --from=builder /app/packages/web/public ./packages/web/public
COPY --from=builder /app/packages/shared/generated ./packages/shared/generated

# Copy Prisma schema for runtime
COPY packages/shared/prisma/schema.prisma ./packages/shared/prisma/

WORKDIR /app/packages/web

CMD ["npx", "next", "start"]
