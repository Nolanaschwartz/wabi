{
  "name": "@wabi/research",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.scripts.json",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "dev": "RESEARCH_PORT=3002 nest start --watch",
    "start:prod": "node dist/main.js",
    "eval:bootstrap": "ts-node scripts/eval-bootstrap.ts",
    "eval:seed": "ts-node scripts/eval-seed.ts",
    "eval:gate": "ts-node scripts/eval-gate.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.68",
    "@langfuse/client": "^5.4.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.1.24",
    "@wabi/shared": "workspace:*",
    "ai": "^6.0.197",
    "pg-boss": "^12.18.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "unpdf": "^1.6.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.8.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testMatch": [
      "**/__tests__/**/*.spec.ts",
      "**/*.spec.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "diagnostics": false
        }
      ]
    }
  }
}
