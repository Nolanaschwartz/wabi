generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String   @id @default(uuid())
  discordId             String   @unique
  email                 String?
  stripeCustomerId      String?  @unique
  trialEndsAt           DateTime?
  subscriptionStatus    String   @default("trialing")
  lastStripeEventAt     DateTime?
  consentAcceptedAt     DateTime?
  locale                String   @default("en-US")
  timezone              String   @default("UTC")
  checkInsEnabled       Boolean  @default(false)
  checkInCadence        String   @default("daily")
  innerStateMemoryEnabled Boolean @default(false)
  innerStateMemoryPromptedAt DateTime?
  quietHoursStart       Int      @default(22)
  quietHoursEnd         Int      @default(8)
  lastCheckIn           DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  sessions Session[]

  @@index([discordId])
  @@index([stripeCustomerId])
}

model Session {
  id          String   @id @default(uuid())
  userId      String
  expiresAt   DateTime
  lastActivity DateTime @default(now())
  mined       Boolean  @default(false)
  doNotMine   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastActivity])
}

model CoachingSession {
  id          String   @id @default(uuid())
  discordId   String   @unique
  expiresAt   DateTime
  lastActivity DateTime @default(now())
  mined       Boolean  @default(false)
  doNotMine   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([discordId])
  @@index([lastActivity])
  @@index([mined])
}

model AiConversation {
  id        String   @id @default(uuid())
  userId    String
  topic     String
  createdAt DateTime @default(now())

  @@index([userId])
}

model Mood {
  id        String   @id @default(uuid())
  userId    String
  rating    Int      // 1-5
  emoji     String
  note      String?
  context   String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model PlaytimeLog {
  id        String   @id @default(uuid())
  userId    String
  duration  Int      // minutes
  game      String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model JournalEntry {
  id        String   @id @default(uuid())
  userId    String
  content   String
  reflection String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model XpEntry {
  id        String   @id @default(uuid())
  userId    String
  amount    Int      // XP points
  reason    String   // journal, mood, streak, etc.
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model TiltSession {
  id        String   @id @default(uuid())
  userId    String
  trigger   String
  severity  Int      // 1-10
  technique String?
  resolved  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([resolved])
  @@index([createdAt])
}

model EscalationEvent {
  id        String   @id @default(uuid())
  userId    String?
  timestamp DateTime @default(now())
  layer     String   @default("tripwire")

  @@index([userId])
  @@index([timestamp])
}

model ProcessedStripeEvent {
  id        String   @id
  type      String
  updatedAt DateTime @updatedAt

  @@unique([id])
  @@index([type])
}

model StrategyDraft {
  id          String   @id @default(uuid())
  title       String
  technique   String
  source      String
  evidence    String
  evidenceTier String?
  lenses      String[] @default([])
  sourceText  String?
  sourceUrl   String
  trustLevel  String   @default("community")
  status      String   @default("pending-review")
  negativeCount Int    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([trustLevel])
  @@index([negativeCount])
}

// Source-level idempotency ledger for the research pipeline (ADR-0033). ID-only — never any
// paper content or personal data. Written by the bot at ingest; read by the worker via GET seen.
model ProcessedSource {
  sourceId    String   @id          // "PMID:12345" | "doi:10.1101/2024.01.01.24300000"
  source      String                // 'pubmed' | 'medrxiv'
  lastStatus  String                // 'submitted' | 'deduped' | 'rejected'
  firstSeenAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Research worker config singleton (ADR-0034). Owned exclusively by the always-on research
// service; the bot never reads or writes it. One row, id="singleton". Holds the schedule and the
// run bounds; Int defaults mirror the RESEARCH_MAX_* env defaults in packages/research/src/config.ts.
// DB is the source of truth after first boot; the env defaults demote to bootstrap seeds only.
model ResearchConfig {
  id                String   @id @default("singleton")
  scheduleCron      String?               // null = unscheduled
  scheduleEnabled   Boolean  @default(false)
  maxTopicsPerRun   Int      @default(5)
  maxPapersPerTopic Int      @default(8)
  maxDiscoverySteps Int      @default(2)
  maxDraftsPerTopic Int      @default(3)
  maxDraftsPerRun   Int      @default(10)
  agentTimeoutMs    Int      @default(90000)
  runTimeoutMs      Int      @default(600000)
  tokenBudget       Int      @default(200000)
  updatedAt         DateTime @updatedAt
}

// Editable research seed topics (ADR-0034). Replaces the hardcoded SEED_TOPICS list; seeded from
// it on first boot when the table is empty. Owned exclusively by the research worker.
model ResearchTopic {
  id        String   @id @default(cuid())
  text      String   @unique
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Research run history / observability (ADR-0034). One row per research run, written by the
// worker's research-run consumer. `trigger` records what fired the run ('scheduled' | 'manual');
// `status` tracks its lifecycle ('running' | 'success' | 'failed'). The count columns mirror the
// run summary the worker computes. A `status='running'` row is the secondary single-flight guard.
// Owned exclusively by the research worker; disjoint from StrategyDraft and user data.
model ResearchRun {
  id         String    @id @default(cuid())
  trigger    String                          // 'scheduled' | 'manual'
  status     String    @default("running")   // 'running' | 'success' | 'failed'
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  submitted  Int       @default(0)
  deduped    Int       @default(0)
  rejected   Int       @default(0)
  errors     Int       @default(0)
  collected  Int       @default(0)
  tokensUsed Int       @default(0)
  topicsRun  Int       @default(0)
  stopReason String?
  error      String?                          // populated on status='failed'

  @@index([startedAt])
}
