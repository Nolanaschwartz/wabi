    "@opentelemetry/context-async-hooks": "^2.8.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@prisma/client": "^6.15.0",
    "ai": "^6.0.197"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "jest": "^29.7.0",
    "prisma": "^6.15.0",
    "ts-jest": "^29.2.0",
    "typescript": "^5.8.2"
  }
