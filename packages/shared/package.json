{
  "name": "@wabi/shared",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sentry-scrub": {
      "types": "./dist/sentry-scrub.d.ts",
      "default": "./dist/sentry-scrub.js"
    },
    "./generate": {
      "types": "./dist/generate.d.ts",
      "default": "./dist/generate.js"
    },
    "./embed": {
      "types": "./dist/embed.d.ts",
      "default": "./dist/embed.js"
    },
    "./otel": {
      "types": "./dist/otel.d.ts",
      "default": "./dist/otel.js"
