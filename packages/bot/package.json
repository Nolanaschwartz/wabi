{
  "name": "@wabi/bot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "PORT=3001 nest start --watch",
    "start:dev": "nest start --watch",
    "start": "nest start",
    "build": "nest build",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.68",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.1.24",
    "@qdrant/qdrant-js": "^1.18.0",
    "@sentry/node": "^10.56.0",
    "@wabi/shared": "workspace:*",
    "ai": "^6.0.197",
    "discord.js": "^14.18.0",
    "necord": "^6.0.0",
    "pg-boss": "^12.18.2",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.13.0",
    "jest": "^29.7.0",
    "testcontainers": "^12.0.1",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.8.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "moduleFileExtensions": [
      "ts",
      "js"
    ],
    "testMatch": [
      "**/__tests__/**/*.spec.ts",
      "**/*.spec.ts"
    ],
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "diagnostics": false
        }
      ]
    },
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ]
  }
}
