{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "outDir": "dist",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@wabi/shared/generate": ["node_modules/@wabi/shared/dist/generate"],
      "@wabi/shared/otel": ["node_modules/@wabi/shared/dist/otel"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
