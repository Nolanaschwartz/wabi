# Discord
DISCORD_TOKEN=your_discord_bot_token_here
# Hub guild whose joins fire the welcome DM (ADR-0015 Task 23). If unset, the welcome is inert.
# Requires the privileged GuildMembers intent enabled in the Discord developer portal.
DISCORD_HUB_GUILD_ID=

# Database
DATABASE_URL=postgresql://wabi:wabi-local@localhost:5433/wabi

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333

# Mem0
MEM0_URL=http://localhost:8081

# Neo4j (mem0 hybrid graph memory, ADR-0025). Self-controlled container holding derived
# personal relationships. NEO4J_PASSWORD is the single source of truth: docker-compose feeds it
# to both neo4j (NEO4J_AUTH=neo4j/<pw>) and mem0 (MEM0_GRAPH_PASSWORD). Setting it enables graph
# memory; leaving MEM0_GRAPH_PASSWORD unset falls mem0 back to vector-only.
# Do NOT commit a real password here — set it in your gitignored .env (or Railway env).
NEO4J_PASSWORD=wabi-local
MEM0_GRAPH_URL=bolt://localhost:7687
MEM0_GRAPH_USERNAME=neo4j

# Inference endpoints (OpenAI-compatible). Per ADR-0017: dev points these at LAN boxes
# (e.g. http://192.168.1.x:PORT); prod points them at the single-tenant managed endpoint(s).
# Do NOT commit real hosts/keys here — set them in your gitignored .env (or Railway env).

# Embeddings (self-hosted, 768-dim)
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=nomic-embed-text-v2-moe.Q4_K_M.gguf
EMBEDDING_API_KEY=

# LLM Providers (swappable per ADR-0009)
COACH_BASE_URL=
COACH_MODEL=qwopus-3.6-27B-mtp:latest
COACH_API_KEY=

CLASSIFIER_BASE_URL=
CLASSIFIER_MODEL=qwopus-3.6-27B-mtp:latest
CLASSIFIER_API_KEY=

# Langfuse
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Stripe (PoC only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Trial
TRIAL_DAYS=7

# GlitchTip (self-hosted Sentry)
SENTRY_DSN=http://admin:password@localhost:8000/1

# Health Check (uptime monitor target)
HEALTH_URL=https://your-wabi-domain.com/health

# Admin (Strategy curation)
# Comma-separated Discord IDs allowed into the web /admin/* surface.
ADMIN_DISCORD_IDS=
# Shared secret the web /api/admin proxy sends to the bot's strategy-admin
# endpoints (x-admin-secret). Must match in both the web and bot environments.
# Unset = strategy-admin endpoints reject every request (fail closed).
ADMIN_API_SECRET=
# Server-side base URL the web admin proxy uses to reach the bot.
BOT_API_URL=http://localhost:3000
