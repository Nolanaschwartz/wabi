# Discord
DISCORD_TOKEN=your_discord_bot_token_here

# Logging
# Controls which levels are emitted: verbose, debug, log, warn, error
# e.g. LOG_LEVEL=debug emits debug+log+warn+error; LOG_LEVEL=warn emits only warn+error
LOG_LEVEL=log
# Hub guild whose joins fire the welcome DM (ADR-0015 Task 23). If unset, the welcome is inert.
# Requires the privileged GuildMembers intent enabled in the Discord developer portal.
DISCORD_HUB_GUILD_ID=

# Database
DATABASE_URL=postgresql://wabi:wabi-local@localhost:5433/wabi

# Redis
REDIS_URL=redis://localhost:6379

# Qdrant
QDRANT_URL=http://localhost:6333

# Mem0
MEM0_URL=http://localhost:8081

# Neo4j (mem0 hybrid graph memory, ADR-0025). Self-controlled container holding derived
# personal relationships. NEO4J_PASSWORD is the single source of truth: docker-compose feeds it
# to both neo4j (NEO4J_AUTH=neo4j/<pw>) and mem0 (MEM0_GRAPH_PASSWORD). Setting it enables graph
# memory; leaving MEM0_GRAPH_PASSWORD unset falls mem0 back to vector-only.
# Do NOT commit a real password here — set it in your gitignored .env (or Railway env).
# Must be at least 8 characters — neo4j 5 rejects shorter passwords and fails to start.
NEO4J_PASSWORD=wabi-local
MEM0_GRAPH_URL=bolt://localhost:7687
MEM0_GRAPH_USERNAME=neo4j

# Inference endpoints (OpenAI-compatible). Per ADR-0017: dev points these at LAN boxes
# (e.g. http://192.168.1.x:PORT); prod points them at the single-tenant managed endpoint(s).
# Do NOT commit real hosts/keys here — set them in your gitignored .env (or Railway env).

# Embeddings (self-hosted, 768-dim)
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=nomic-embed-text-v2-moe.Q4_K_M.gguf
EMBEDDING_API_KEY=

# LLM Providers (swappable per ADR-0009)
COACH_BASE_URL=
COACH_MODEL=qwopus-3.6-27B-mtp:latest
COACH_API_KEY=

CLASSIFIER_BASE_URL=
CLASSIFIER_MODEL=qwopus-3.6-27B-mtp:latest
CLASSIFIER_API_KEY=

# Intent router: dispatches free-form DMs to specialised handlers (journal/tilt/mood/coach). A small,
# fast classify model — NOT a safety surface (a misconfigured router fails soft to coaching).
ROUTER_BASE_URL=
ROUTER_MODEL=qwopus-3.6-27B-mtp:latest
ROUTER_API_KEY=

# --- Research worker (Part B) ---
# Capable extraction model. Falls back to COACH_* when unset (so a local setup works without a
# separate research endpoint); set these to split extraction onto its own tier in production.
RESEARCH_BASE_URL=
RESEARCH_MODEL=
RESEARCH_API_KEY=
# Cheap triage model (relevance gate + in-run dedup); falls back to CLASSIFIER_* when unset:
RESEARCH_TRIAGE_BASE_URL=
RESEARCH_TRIAGE_MODEL=
RESEARCH_TRIAGE_API_KEY=
# LLM output-token caps. MUST be generous for reasoning models: hidden reasoning tokens come out of
# the same output budget, so a small cap returns EMPTY text and the call silently no-ops (a 5-token
# gate dropped every paper against the local qwopus-3.6 MTP model). Verified mins: triage ~2k, extract ~4k.
RESEARCH_TRIAGE_MAX_TOKENS=2000
RESEARCH_MAX_TOKENS=4000
# Bot-side trust gate (safety + faithfulness) output cap — same reasoning-model concern; a 10-token
# cap returned empty and rejected every research-agent draft. Lives on the bot, not the worker.
STRATEGY_GATE_MAX_TOKENS=2000
# Worker → strategy-ingest target (ADR-0034). The worker prefers STRATEGY_API_URL and falls back to
# BOT_BASE_URL; today they point at the same bot. The seam lets a future Strategy-API extraction be
# an env flip with no code change. Candidates still flow over HTTP to the bot's trust gate.
STRATEGY_API_URL=http://localhost:3001
BOT_BASE_URL=http://localhost:3001
# The research worker is now an always-on NestJS service (ADR-0034). It needs DATABASE_URL (scoped
# to research tables + the pg-boss queue only — never user data, never StrategyDraft) and reuses
# ADMIN_API_SECRET (below) to guard its own /admin/research endpoints. It binds RESEARCH_PORT.
RESEARCH_PORT=3002
RESEARCH_TZ=UTC                        # timezone cron schedules are interpreted in
NCBI_API_KEY=                          # optional; raises NCBI E-utilities rate cap above 3 req/s
RESEARCH_DEDUP_THRESHOLD=0.95          # cosine ≥ this = library duplicate (bot-side)
# Bounds & budget — SEED DEFAULTS ONLY (ADR-0034). After first boot, DB (ResearchConfig) is the
# source of truth for these; the worker seeds the singleton row from these defaults once, then the
# operator edits them in /admin/research. (defaults shown):
# PubMed full text: PMC open-access BioC JSON, falling back to Europe PMC OA full-text XML. Either
# path is truncated to this many characters to bound token cost (non-OA papers read the abstract).
RESEARCH_PUBMED_MAX_TEXT_CHARS=50000
# medRxiv scans a recent window client-side; the details API pages 100 records at a time out of
# thousands. This caps how many it pages through per window (cached per run). Higher = more coverage,
# slower start. The full window total is logged so you can see the coverage fraction.
RESEARCH_MEDRXIV_MAX_RECORDS=1500
# Fraction of a query's content terms a medRxiv record must contain (whole-word) to be kept, for
# queries with >2 terms. Lower = more recall (looser), higher = stricter. The relevance gate filters
# the rest. 0.5 = "at least half the terms".
RESEARCH_MEDRXIV_MIN_TERM_FRACTION=0.5
# medRxiv full text comes from the open-access PDF (<doi>v<version>.full.pdf). Caps below bound the
# download size and the extracted-text length (oversize/parse failures fall back to the abstract).
RESEARCH_MEDRXIV_MAX_PDF_BYTES=20000000
RESEARCH_MEDRXIV_MAX_TEXT_CHARS=50000
# PsyArXiv (OSF API v2) — third evidence source, same windowed-scan + term-match rules as medRxiv.
# OSF_TOKEN is an optional personal access token (https://osf.io/settings/tokens) that raises the
# anonymous rate limit; the source works without it. Window/cap/fraction mirror the medRxiv knobs.
OSF_TOKEN=
RESEARCH_PSYARXIV_WINDOW_DAYS=60
RESEARCH_PSYARXIV_MAX_RECORDS=1500
RESEARCH_PSYARXIV_MIN_TERM_FRACTION=0.5
# PsyArXiv full text comes from the preprint's primary-file PDF (resolved via the OSF file node).
# Caps below bound the download size and extracted-text length (failures fall back to the abstract).
RESEARCH_PSYARXIV_MAX_PDF_BYTES=20000000
RESEARCH_PSYARXIV_MAX_TEXT_CHARS=50000
RESEARCH_MAX_TOPICS_PER_RUN=5
RESEARCH_MAX_PAPERS_PER_TOPIC=8
RESEARCH_MAX_DISCOVERY_STEPS=2
RESEARCH_MAX_DRAFTS_PER_TOPIC=3
RESEARCH_MAX_DRAFTS_PER_RUN=10
RESEARCH_AGENT_TIMEOUT_MS=90000
RESEARCH_RUN_TIMEOUT_MS=600000
RESEARCH_TOKEN_BUDGET=200000
# Progress logging to stderr: silent | info (default) | debug (per-paper gate/body/discovery detail):
RESEARCH_LOG_LEVEL=info

# Langfuse
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Per-turn trace sampling. Decided once per turn (binary): unsampled turns send NOTHING — no
# content-bearing payload is posted. Explicit value wins; else 0.1 in production, 1.0 otherwise.
LANGFUSE_SAMPLE_RATE=

# Stripe (PoC only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Trial
TRIAL_DAYS=7

# GlitchTip (self-hosted Sentry)
SENTRY_DSN=http://admin:password@localhost:8000/1

# Health Check (uptime monitor target)
HEALTH_URL=https://your-wabi-domain.com/health

# Admin (Strategy curation)
# Comma-separated Discord IDs allowed into the web /admin/* surface.
ADMIN_DISCORD_IDS=
# Shared secret the web /api/admin proxy sends to the bot's strategy-admin AND the research worker's
# research-admin endpoints (x-admin-secret) — one secret, both backends (ADR-0034). Must match in
# the web, bot, and research-worker environments. Unset = both admin surfaces reject every request
# (fail closed).
ADMIN_API_SECRET=
# Server-side base URL the web admin proxy uses to reach the bot (the bot binds :3001; web owns :3000).
BOT_API_URL=http://localhost:3001
# Server-side base URL the web admin proxy uses to reach the research worker (ADR-0034).
RESEARCH_API_URL=http://localhost:3002
